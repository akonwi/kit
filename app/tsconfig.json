{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM"],
		"strict": true,
		"skipLibCheck": true,
		"jsx": "preserve",
		"jsxImportSource": "@opentui/solid",
		"types": ["bun"],
		"noEmit": true,
		"allowJs": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "src/vendor/**/*.js"]
}
