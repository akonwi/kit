#!/bin/bash
# Launch pi-kit from any directory.
# Resolves symlinks to find the real project root, then runs with
# the project's bunfig.toml (needed for JSX/preload config).

# Resolve symlinks to find the real script location
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # If readlink returns a relative path, resolve it
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

export KIT_USER_CWD="${KIT_USER_CWD:-$(pwd)}"
cd "$PROJECT_ROOT"
exec bun run "$PROJECT_ROOT/src/app/main.tsx" "$@"
