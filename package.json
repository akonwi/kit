{
	"name": "kit",
	"version": "0.1.0",
	"private": true,
	"description": "Standalone kit app with Pi-core compatibility and a custom terminal shell.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"kit": "./dist/kit"
	},
	"scripts": {
		"check": "biome check --write .",
		"lint:staged": "biome check --write --staged --unsafe .",
		"dev": "bun --preload=@opentui/solid/preload src/app/main.tsx",
		"start": "bun --preload=@opentui/solid/preload src/app/main.tsx",
		"build": "bun run script/build.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.62.0",
		"@mariozechner/pi-ai": "^0.62.0",
		"@opentui/core": "0.1.102",
		"@opentui/solid": "0.1.102",
		"@pierre/diffs": "^1.1.16",
		"ignore": "^7.0.5",
		"solid-js": "^1.9.0",
		"web-tree-sitter": "0.25.10",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.0"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
