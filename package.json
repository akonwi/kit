{
	"name": "@akonwi/kit",
	"version": "0.4.1",
	"author": "Akonwi Ngoh <akonwi@gmail.com>",
	"description": "A TUI coding agent",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akonwi/kit.git"
	},
	"homepage": "https://github.com/akonwi/kit#readme",
	"bugs": {
		"url": "https://github.com/akonwi/kit/issues"
	},
	"bin": {
		"kit": "dist/kit"
	},
	"exports": {
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"default": "./dist/plugin.js"
		}
	},
	"typesVersions": {
		"*": {
			"plugin": [
				"dist/plugin.d.ts"
			]
		}
	},
	"files": [
		"dist/",
		"docs/features/plugins.md",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"check": "biome check --write .",
		"lint:staged": "biome check --write --staged --unsafe .",
		"dev": "bun --preload=@opentui/solid/preload src/app/main.tsx",
		"start": "bun --preload=@opentui/solid/preload src/app/main.tsx",
		"build": "bun run script/build.ts",
		"pack:dry": "npm pack --dry-run",
		"prepack": "bun run build",
		"prepublishOnly": "bun run typecheck && bun test",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "^0.74.0",
		"@earendil-works/pi-ai": "^0.74.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@opentui/core": "0.2.2",
		"@opentui/solid": "0.2.2",
		"@pierre/diffs": "^1.1.16",
		"glob": "^13.0.6",
		"ignore": "^7.0.5",
		"solid-js": "1.9.12",
		"typebox": "^1.1.24",
		"web-tree-sitter": "0.25.10",
		"yaml": "^2.8.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"typescript": "^5.9.0"
	},
	"engines": {
		"bun": ">=1.3.0"
	}
}
